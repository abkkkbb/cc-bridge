# ============================================
# Claude Code Gateway Docker Compose 示例配置
# ============================================

# --- 服务器 ---
SERVER_HOST=0.0.0.0
SERVER_PORT=5674

# --- TLS（可选，留空则使用 HTTP） ---
# TLS_CERT_FILE=/path/to/cert.pem
# TLS_KEY_FILE=/path/to/key.pem

# --- 数据库（PostgreSQL / Docker Compose）---
DATABASE_DRIVER=sqlite
# 留空时：程序会直接使用 docker compose 中的 postgres 容器，
# 并在目标数据库不存在时自动创建
# DATABASE_DSN=postgres://cc-bridge:cc-bridge@127.0.0.1:5432/cc-bridge?sslmode=disable

# PostgreSQL 容器初始化参数（供 docker compose 的 postgres 服务使用）
POSTGRES_USER=cc-bridge
POSTGRES_PASSWORD=cc-bridge
POSTGRES_DB=cc-bridge

# --- Redis（可选，留空则使用内存缓存） ---
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# --- 管理员 ---
ADMIN_PASSWORD=admin

# --- 日志 ---
# 级别: debug, info, warn, error
LOG_LEVEL=info

# --- 用量轮询 ---
# 账户 usage 数据自动刷新间隔（秒），默认 600（10 分钟）
USAGE_POLL_INTERVAL_SECS=600
